{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "l9://intelligence/generated-invariant/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "invariant_id",
    "candidate_id",
    "statement",
    "scope",
    "severity",
    "evidence",
    "state"
  ],
  "properties": {
    "schema_version": {
      "const": "l9.generated-invariant/v1"
    },
    "invariant_id": {
      "type": "string",
      "pattern": "^invariant_[0-9a-f]{64}$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^candidate_[0-9a-f]{64}$"
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "enum": ["info", "warning", "error"]
    },
    "evidence": {
      "type": "object",
      "required": [
        "source_snapshot_id",
        "analysis_run_id",
        "recurrence_fingerprint"
      ]
    },
    "state": {
      "const": "candidate"
    }
  }
}
