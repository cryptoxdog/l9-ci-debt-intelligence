{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/cryptoxdog/l9-ci-debt-intelligence/schemas/cooccurrence.schema.json",
  "title": "Co-occurrence Matrix",
  "description": "Rule_id co-occurrence counts across PR findings",
  "type": "object",
  "required": ["generated_at", "source", "pr_count", "matrix"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "source":       { "type": "string", "enum": ["corpus", "fixture"] },
    "pr_count":     { "type": "integer", "minimum": 0 },
    "leverage_score": { "type": ["number", "string"] },
    "matrix": {
      "type": "object",
      "description": "Keys are rule_ids. Values are objects mapping co-occurring rule_id to count.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "number" }
      }
    }
  }
}
