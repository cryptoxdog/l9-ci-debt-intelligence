{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CorpusFinding",
  "type": "object",
  "required": ["finding_id", "classification", "rule_id", "repo", "tenant_id", "language", "ci_system", "action"],
  "properties": {
    "pr":             { "type": "integer" },
    "cycle":          { "type": "integer" },
    "finding_id":     { "type": "string", "minLength": 1 },
    "source":         { "type": "string", "enum": ["gha_log", "code_review", "manual", "fixture"] },
    "severity":       { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
    "classification": { "type": "string", "enum": ["valid_current", "unknown", "doctrine_reject", "out_of_scope"] },
    "location":       { "type": "string" },
    "description":    { "type": "string" },
    "action":         { "type": "string", "enum": ["patch", "not_patched"] },
    "rule_id":        { "type": "string" },
    "repo":           { "type": "string" },
    "tenant_id":      { "type": "string" },
    "language":       { "type": "string" },
    "ci_system":      { "type": "string" }
  },
  "additionalProperties": true
}
