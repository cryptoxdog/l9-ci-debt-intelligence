{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/cryptoxdog/l9-ci-debt-intelligence/schemas/effort_atlas.schema.json",
  "title": "Effort Atlas",
  "description": "Per-rule effort cost derived from resolver corpus",
  "type": "object",
  "required": ["generated_at", "source", "rules"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "source":       { "type": "string", "enum": ["corpus", "fixture"] },
    "corpus_size":  { "type": "integer", "minimum": 0 },
    "leverage_score": { "type": ["number", "string"] },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "occurrence_count", "effort_score"],
        "properties": {
          "rule_id":                { "type": "string" },
          "topology":               { "type": ["string", "null"] },
          "occurrence_count":       { "type": "integer", "minimum": 0 },
          "avg_cycles_to_fix":      { "type": ["number", "string"] },
          "avg_gate_failures":      { "type": ["number", "string"] },
          "prs_affected":           { "type": "integer", "minimum": 0 },
          "effort_score":           { "type": ["number", "string"] },
          "doctrine_reject_count":  { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
